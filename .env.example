# Copy to .env.local for local dev. NEVER commit real keys.
# In production, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# OpenAI-compatible API serving the course models (4UHRUIN-*).
# Base URL + key are provided by the course.
OPENAI_API_KEY=your-course-api-key-here
OPENAI_BASE_URL=https://your-course-endpoint.example.com/v1

# Model names (fixed by the assignment; override only if the course changes them).
EMBEDDING_MODEL=4UHRUIN-text-embedding-3-small
CHAT_MODEL=4UHRUIN-gpt-5-mini

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=medium-rag
